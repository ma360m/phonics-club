# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PHONICS CLUB
ADMIN_EMAIL=phonicsclub@gmail.com

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Storage bucket (created by migration 004)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=product-images

# Cloudinary (optional — admin can also use Supabase Storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ADMIN_UPLOAD_MAX_MB=5

# Order confirmation emails (optional — Resend)
RESEND_API_KEY=
ORDER_EMAIL_FROM=orders@phonicsclub.com
